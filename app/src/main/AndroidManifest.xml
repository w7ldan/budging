<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".BudgingApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Budging">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".quickaccess.OpenDashboardActivity"
            android:exported="true"
            android:theme="@style/Theme.Budging" />

        <activity
            android:name=".quickaccess.OpenLogExpenseActivity"
            android:exported="true"
            android:theme="@style/Theme.Budging" />

        <activity
            android:name=".quickaccess.OpenHistoryActivity"
            android:exported="true"
            android:theme="@style/Theme.Budging" />

        <receiver
            android:name=".widget.BudgingStatusWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/budging_status_widget_info" />
        </receiver>

        <service
            android:name=".quicktile.LogExpenseTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_log_expense"
            android:label="Log Expense"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
